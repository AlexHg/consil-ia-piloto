# --- Base de datos (Docker Compose) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=reconciliation
POSTGRES_PORT=5432

# Cadena de conexión usada por la app
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Cola de trabajos (pg-boss) ---
# pg-boss usa la misma DATABASE_URL pero en su propio esquema, aislado del dominio.
# Crea/migra sus tablas automáticamente al iniciar el servidor.
PGBOSS_SCHEMA=pgboss

# --- IA (opcional) ---
# La IA solo se usa para explicaciones, interpretación de notas y OCR.
# Nunca decide la conciliación. Si no se define, se usa un proveedor mock.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
