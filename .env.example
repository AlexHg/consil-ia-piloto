# --- Database (Docker Compose) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=reconciliation
POSTGRES_PORT=5432

# Connection string used by the app
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Job queue (pg-boss) ---
# pg-boss uses the same DATABASE_URL but in its own schema, isolated from the domain.
# It creates/migrates its tables automatically when the server starts.
PGBOSS_SCHEMA=pgboss

# --- AI (optional) ---
# AI is only used for explanations, note interpretation, and OCR.
# It never decides reconciliation. If not set, a mock provider is used.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
