# --- Base de datos (Docker Compose) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=reconciliation
POSTGRES_PORT=5432

# Cadena de conexión usada por la app
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

# --- IA (opcional) ---
# La IA solo se usa para explicaciones, interpretación de notas y OCR.
# Nunca decide la conciliación. Si no se define, se usa un proveedor mock.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
